# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=10001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:@localhost:3306/ahansk

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ─── Redis (Queue + Cache) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Google reCAPTCHA ─────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:10002
ADMIN_URL=http://localhost:10003

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ahansk.local

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: local | s3
DISK=local
STORAGE_LOCAL_PATH=./uploads

# S3-compatible (required only if DISK=s3)
# S3_ENDPOINT=https://s3.example.com
# S3_BUCKET=my-bucket
# S3_REGION=auto
# S3_KEY=your-access-key
# S3_SECRET=your-secret-key

# ─── Web Push / VAPID (wajib jika ingin push notification aktif) ─────────────
# Generate: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-base64url
VAPID_CONTACT_EMAIL=admin@yourdomain.com
