# ─── App Server ───────────────────────────────────────────────────────────────
# NODE_ENV: development, production, atau test
NODE_ENV=production
# PORT: Port aplikasi backend akan berjalan (default: 10311)
PORT=10311

# ─── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL: URL koneksi Prisma (Format: mysql://USER:PASSWORD@HOST:PORT/DB_NAME)
DATABASE_URL=mysql://root:dummy-db-password@localhost:3306/ahansk

# ─── JWT Authentication ───────────────────────────────────────────────────────
# JWT_ACCESS_SECRET & JWT_REFRESH_SECRET: Gunakan string acak minimal 32 karakter!
JWT_ACCESS_SECRET=dummy-access-secret-min-32-chars-for-production!
JWT_REFRESH_SECRET=dummy-refresh-secret-min-32-chars-for-production!
# Kedaluwarsa token (Access dalam menit/jam, Refresh dalam hari)
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ─── Redis (Queue + Cache) ────────────────────────────────────────────────────
# REDIS_URL: URL koneksi ke Redis Server
REDIS_URL=redis://localhost:6379

# ─── Google OAuth (Opsional) ──────────────────────────────────────────────────
# GOOGLE_CLIENT_ID: Client ID dari Google Cloud Console (Kosong = Login Google nonaktif)
GOOGLE_CLIENT_ID=dummy-google-client-id.apps.googleusercontent.com

# ─── Google reCAPTCHA (Opsional) ──────────────────────────────────────────────
# RECAPTCHA_SECRET_KEY: Secret Key dari reCAPTCHA (Kosong = verifikasi captcha nonaktif)
RECAPTCHA_SECRET_KEY=dummy-recaptcha-secret-key

# ─── CORS (Sangat Penting di Production) ──────────────────────────────────────
# FRONTEND_URL & ADMIN_URL: Domain asli dari frontend dan admin agar terhindar dari error CORS
FRONTEND_URL=https://ahansk.com
ADMIN_URL=https://admin.ahansk.com

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Kredensial server SMTP untuk pengiriman notifikasi, verifikasi, dsb.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dummy-email@gmail.com
SMTP_PASS=dummy-app-password
SMTP_FROM_NAME=Ahansk
SMTP_FROM_ADDRESS=noreply@ahansk.com

# ─── Storage (Upload File) ────────────────────────────────────────────────────
# DISK: 'local' untuk simpan di server, 's3' untuk simpan di AWS/MinIO/Cloudflare R2
DISK=local
# PATH penyimpanan lokal (jika DISK=local)
STORAGE_LOCAL_PATH=./uploads

# ─── S3-compatible (Wajib diisi jika DISK=s3) ─────────────────────────────────
# S3_ENDPOINT=https://s3.example.com
# S3_BUCKET=my-bucket
# S3_REGION=auto
# S3_KEY=dummy-s3-access-key
# S3_SECRET=dummy-s3-secret-key

# ─── Web Push / VAPID (Wajib jika push notification diaktifkan) ───────────────
# Cara Generate Key: Jalankan perintah ini di terminal server Anda:
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=dummy-vapid-public-key-base64url
VAPID_PRIVATE_KEY=dummy-vapid-private-key-base64url
VAPID_CONTACT_EMAIL=admin@ahansk.com
