# ─── Deployment & Server ──────────────────────────────────────────────────────
# PORT: Port aplikasi akan berjalan (default: 10312)
PORT=10312

# NEXT_BASE_PATH: Kosongkan untuk subdomain/root (domain.com)
# Isi prefix jika diletakkan di sub-path (misal: /app)
NEXT_BASE_PATH=

# ─── Backend API ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL: URL lengkap ke backend API
NEXT_PUBLIC_API_URL=http://localhost:10311

# ─── Dashboard prefix ────────────────────────────────────────────────────────
# NEXT_PUBLIC_DASHBOARD_PATH: Prefix URL untuk dashboard user (Ganti ke /app, /dash, dll sesuai kebutuhan)
NEXT_PUBLIC_DASHBOARD_PATH=/dashboard

# ─── Google OAuth (One Tap) ───────────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_CLIENT_ID: Client ID dari Google Cloud Console (Kosongkan jika tidak pakai login Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=dummy-google-client-id.apps.googleusercontent.com

# ─── Google reCAPTCHA ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY: Site Key dari reCAPTCHA v2/v3 (Kosongkan jika captcha dimatikan)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=dummy-recaptcha-site-key
