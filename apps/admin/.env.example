# ─── Deployment ────────────────────────────────────────────────────────────
# Kosongkan untuk subdomain (admin.domain.com)
# Isi "/admin" untuk single domain (domain.com/admin)
NEXT_BASE_PATH=

# ─── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:10001

# ─── Frontend URL (for logo/favicon SSOT) ────────────────────────────────────
NEXT_PUBLIC_FRONTEND_URL=http://localhost:10002

# ─── Google reCAPTCHA ─────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
