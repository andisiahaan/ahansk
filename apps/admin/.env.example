# ─── Deployment & Server ──────────────────────────────────────────────────────
# PORT: Port aplikasi akan berjalan (default: 10313)
PORT=10313

# NEXT_BASE_PATH: Kosongkan untuk subdomain (admin.domain.com)
# Isi "/admin" untuk single domain (domain.com/admin)
NEXT_BASE_PATH=

# ─── Backend API ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL: URL lengkap ke backend API
NEXT_PUBLIC_API_URL=http://localhost:10311

# ─── Frontend URL ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_FRONTEND_URL: URL publik ke frontend utama (untuk integrasi logo/favicon SSOT)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:10312

# ─── Google reCAPTCHA ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY: Site Key dari reCAPTCHA v2/v3 (Kosongkan jika captcha dimatikan)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=dummy-recaptcha-site-key
